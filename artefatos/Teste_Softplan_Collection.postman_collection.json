            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Defina suas credenciais aqui",
                  "pm.environment.set('username', 'seu_usuario');",
                  "pm.environment.set('password', 'sua_senha');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "string"
                }
              ]
