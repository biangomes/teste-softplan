            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"COLOQUE_O_NOME_AQUI\",\n  \"cpf\": \"COLOQUE_O_CPF_AQUI\",\n  \"sexo\": \"H_OU_M_OU_DEIXE_VAZIO\",\n  \"email\": \"COLOQUE_O_EMAIL_AQUI_OU_DEIXE_VAZIO\",\n  \"dataNascimento\": \"DD/MM/YYYY\",\n  \"estado\": \"UF_COLOQUE_AQUI_OU_DEIXE_VAZIO\",\n  \"pais\": \"COLOQUE_O_PAIS_AQUI_OU_DEIXE_VAZIO\"\n}"
